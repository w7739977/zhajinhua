page {
  background-color: #121212;
  color: #f9fafb;
  font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
}

text {
  color: inherit;
}

button {
  border-radius: 0;
  background: none;
  border: none;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

button::after {
  border: none;
  display: none;
}

input, textarea {
  box-sizing: border-box;
  -webkit-box-sizing: border-box;
}
