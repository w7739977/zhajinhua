.room-page {
  min-height: 100vh;
  padding: 32rpx 32rpx 180rpx;
  background: #121212;
  box-sizing: border-box;
}

.room-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.room-id {
  font-size: 28rpx;
  color: #e5e7eb;
}

.invite-btn {
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.12);
  color: #bfdbfe;
  border: 1rpx solid rgba(129, 140, 248, 0.6);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.6);
}

.other-players {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.other-player-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.other-player-item .avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #27272a;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.02);
}

.other-player-item .nickname {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.center-card {
  text-align: center;
  margin-bottom: 40rpx;
  min-height: 80rpx;
}

.center-card-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
  display: block;
}

/* 扑克牌：暗色背景下的白卡片 */
.poker-card {
  width: 70rpx;
  height: 100rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(243, 244, 246, 0.24);
  background: #f9fafb;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 35rpx rgba(0, 0, 0, 0.75);
}

.poker-card-large {
  width: 80rpx;
  height: 110rpx;
  display: inline-flex;
  margin-left: 8rpx;
}

.poker-card-text {
  font-size: 24rpx;
  color: #111827;
}

.self-block {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}


.self-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 999rpx;
  background: #27272a;
  border: 3rpx solid rgba(255, 255, 255, 0.08);
}

.avatar-pending {
  border-color: rgba(107, 114, 128, 0.45) !important;
  box-shadow: 0 0 0 6rpx rgba(107, 114, 128, 0.08);
}

.avatar-ready {
  border-color: rgba(96, 165, 250, 0.85) !important;
  box-shadow: 0 0 0 6rpx rgba(37, 99, 235, 0.14);
}

.avatar-dealt {
  border-color: rgba(52, 211, 153, 0.92) !important;
  box-shadow: 0 0 0 6rpx rgba(16, 185, 129, 0.16);
}

.self-nickname {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #f9fafb;
}

.self-card-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.self-hand-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.self-hand-card {
  font-size: 24rpx;
  color: #9ca3af;
}

.self-hand-card.placeholder {
  margin-top: 16rpx;
}

.bottom-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 40rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.btn {
  width: 48%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.8);
}

.btn-primary {
  background: #2563eb;
  color: #f9fafb;
}

.btn-secondary {
  background: #27272a;
  color: #e5e7eb;
}

.btn[disabled] {
  opacity: 0.35;
  box-shadow: none;
}


.ready-tag {
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(34, 197, 94, 0.16);
  color: #86efac;
  font-size: 20rpx;
}

.ready-tag.pending {
  background: rgba(107, 114, 128, 0.16);
  color: #9ca3af;
}

.deal-tag {
  margin-top: 6rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.16);
  color: #93c5fd;
  font-size: 20rpx;
}

.deal-tag.pending {
  background: rgba(107, 114, 128, 0.12);
  color: #6b7280;
}

.self-ready {
  margin-top: 8rpx;
}

.bottom-bar-three {
  gap: 12rpx;
}

.bottom-bar-three .btn {
  width: 31%;
  font-size: 26rpx;
}
