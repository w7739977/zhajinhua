.room-page {
  min-height: 100vh;
  padding: 32rpx 32rpx 280rpx;
  background:
    radial-gradient(circle at 50% 26%, rgba(110, 231, 183, 0.12), transparent 20%),
    radial-gradient(circle at 22% 18%, rgba(16, 185, 129, 0.08), transparent 24%),
    radial-gradient(circle at 78% 20%, rgba(16, 185, 129, 0.08), transparent 24%),
    radial-gradient(circle at 50% 100%, rgba(0, 0, 0, 0.36), transparent 40%),
    linear-gradient(180deg, #163e2f 0%, #0d291f 50%, #081510 100%);
  box-sizing: border-box;
  box-shadow:
    inset 0 0 140rpx rgba(0, 0, 0, 0.22),
    inset 0 0 26rpx rgba(255, 255, 255, 0.02);
}

.room-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.room-id {
  font-size: 28rpx;
  color: #e5e7eb;
}

.invite-btn {
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.12);
  color: #bfdbfe;
  border: 1rpx solid rgba(129, 140, 248, 0.6);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.6);
}

/* ========== 测试面板 ========== */

.mock-panel {
  margin-bottom: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(8, 27, 20, 0.72);
  border: 1rpx solid rgba(110, 231, 183, 0.12);
  box-shadow: 0 16rpx 36rpx rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(8rpx);
}

.mock-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.mock-panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #f9fafb;
}

.mock-panel-meta {
  font-size: 22rpx;
  color: #93c5fd;
}

.mock-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.mock-btn {
  width: calc(50% - 8rpx);
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  background: rgba(37, 99, 235, 0.12);
  color: #dbeafe;
  font-size: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.28);
}

.mock-btn.danger {
  border-color: rgba(248, 113, 113, 0.2);
  background: rgba(127, 29, 29, 0.22);
  color: #fecaca;
}

/* ========== 桌面区域 ========== */

.table-stage {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 32rpx;
  min-height: 520rpx;
}

.side-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.left-column {
  align-items: flex-start;
}

.right-column {
  align-items: flex-end;
}

.center-zone {
  position: relative;
  width: 250rpx;
  min-height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 50% 50%, rgba(110, 231, 183, 0.16), rgba(34, 197, 94, 0.05) 42%, rgba(0, 0, 0, 0) 72%),
    radial-gradient(circle at 50% 50%, rgba(5, 46, 22, 0.42), rgba(2, 6, 23, 0.08) 72%);
  box-shadow:
    inset 0 0 40rpx rgba(16, 185, 129, 0.08),
    0 14rpx 40rpx rgba(0, 0, 0, 0.18);
}

.center-zone::after {
  content: '';
  position: absolute;
  inset: 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(220, 252, 231, 0.06);
}

/* ========== 其他玩家 ========== */

.other-player-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 150rpx;
  padding: 22rpx 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.045);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04),
    0 10rpx 24rpx rgba(0, 0, 0, 0.12);
  transition: all 0.2s;
}

.player-selected {
  background: rgba(250, 204, 21, 0.12) !important;
  border: 2rpx solid rgba(250, 204, 21, 0.6);
  box-shadow: 0 0 20rpx rgba(250, 204, 21, 0.15);
}

.left-column .other-player-item {
  align-self: flex-start;
}

.right-column .other-player-item {
  align-self: flex-end;
}

.avatar-wrap {
  position: relative;
  display: inline-block;
}

.avatar-wrap-self {
  display: inline-block;
}

.other-player-item .avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #27272a;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.02);
}

.seat-base {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  transform: translateX(-50%);
  width: 92rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 50% 50%, rgba(12, 18, 16, 0.42), rgba(12, 18, 16, 0.02) 78%);
  filter: blur(2rpx);
}

.other-player-item .nickname {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9ca3af;
  max-width: 100%;
  line-height: 1.35;
  text-align: center;
  word-break: break-all;
}

/* ========== 庄家标识 ========== */

.avatar-dealer {
  border: 4rpx solid rgba(250, 204, 21, 0.92) !important;
  box-shadow: 0 0 0 6rpx rgba(250, 204, 21, 0.18), 0 0 16rpx rgba(250, 204, 21, 0.12);
}

.crown-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  font-size: 28rpx;
  z-index: 2;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.5));
}

.crown-badge-self {
  top: -12rpx;
  right: -12rpx;
  font-size: 34rpx;
}

/* ========== 头像状态 ========== */

.avatar-pending {
  border-color: rgba(107, 114, 128, 0.45) !important;
  box-shadow: 0 0 0 6rpx rgba(107, 114, 128, 0.08);
}

.avatar-dealt {
  border-color: rgba(52, 211, 153, 0.92) !important;
  box-shadow: 0 0 0 6rpx rgba(16, 185, 129, 0.16);
}

/* ========== 公牌区 ========== */

.center-card {
  text-align: center;
  width: 100%;
  min-height: 210rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: rgba(6, 20, 15, 0.26);
  border: 1rpx solid rgba(110, 231, 183, 0.1);
  box-shadow:
    inset 0 0 24rpx rgba(255, 255, 255, 0.02),
    0 12rpx 28rpx rgba(0, 0, 0, 0.14);
}

.card-placeholder {
  width: 100%;
  min-height: 210rpx;
  border-radius: 24rpx;
  background: rgba(7, 21, 16, 0.22);
  border: 1rpx dashed rgba(110, 231, 183, 0.18);
}

.center-card-label {
  font-size: 24rpx;
  color: rgba(220, 252, 231, 0.78);
  letter-spacing: 2rpx;
  margin-bottom: 18rpx;
  display: block;
}

/* ========== 扑克牌 ========== */

.poker-card {
  width: 70rpx;
  height: 100rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(243, 244, 246, 0.24);
  background: #f9fafb;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 35rpx rgba(0, 0, 0, 0.75);
  animation: cardReveal 360ms ease-out;
}

.poker-card-large {
  width: 90rpx;
  height: 126rpx;
  display: inline-flex;
  margin-left: 0;
  box-shadow:
    0 18rpx 40rpx rgba(0, 0, 0, 0.42),
    0 0 28rpx rgba(255, 255, 255, 0.1);
}

.poker-card-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.poker-card-text-red {
  color: #dc2626;
}

/* ========== 自己区域 ========== */

.self-block {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: 250rpx;
  min-width: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx 20rpx;
  border-radius: 28rpx;
  background: rgba(8, 27, 20, 0.48);
  border: 1rpx solid rgba(110, 231, 183, 0.1);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.2);
}

.self-seat-base {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  transform: translateX(-50%);
  width: 130rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 50% 50%, rgba(12, 18, 16, 0.54), rgba(12, 18, 16, 0.02) 82%);
  filter: blur(3rpx);
}

.self-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 999rpx;
  background: #27272a;
  border: 3rpx solid rgba(255, 255, 255, 0.08);
}

.self-nickname {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #f9fafb;
}

.self-card-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.self-card-row .poker-card {
  animation-duration: 420ms;
}

.self-hand-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.self-hand-card {
  font-size: 24rpx;
  color: #9ca3af;
}

.self-hand-card.placeholder {
  margin-top: 16rpx;
}

.self-bet-info {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #fde68a;
}

/* ========== 状态标签 ========== */

.deal-tag {
  margin-top: 6rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.16);
  color: #93c5fd;
  font-size: 20rpx;
}

.deal-tag.pending {
  background: rgba(107, 114, 128, 0.12);
  color: #6b7280;
}

.bet-tag {
  margin-top: 6rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(250, 204, 21, 0.16);
  color: #fde68a;
  font-size: 20rpx;
}

.bet-tag.pending {
  background: rgba(107, 114, 128, 0.12);
  color: #6b7280;
}

.score-tag {
  margin-top: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(239, 68, 68, 0.14);
  color: #fca5a5;
  font-size: 26rpx;
  font-weight: 600;
}

.score-tag-self {
  margin-top: 8rpx;
  font-size: 28rpx;
}

.mock-tag {
  margin-top: 6rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(168, 85, 247, 0.14);
  color: #d8b4fe;
  font-size: 18rpx;
}

/* ========== 底部操作栏 ========== */

.bottom-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 40rpx;
  padding: 18rpx 18rpx 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background:
    linear-gradient(180deg, rgba(18, 45, 34, 0.72) 0%, rgba(7, 20, 15, 0.84) 100%);
  border: 1rpx solid rgba(220, 252, 231, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
    0 16rpx 36rpx rgba(0, 0, 0, 0.28);
  backdrop-filter: blur(8rpx);
}

.bottom-bar-open {
  gap: 10rpx;
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.28);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08),
    inset 0 -8rpx 14rpx rgba(0, 0, 0, 0.12),
    0 12rpx 28rpx rgba(0, 0, 0, 0.28);
}

.btn-full {
  width: 100%;
}

.btn-sm {
  width: 30%;
  font-size: 24rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.btn-primary {
  background:
    linear-gradient(180deg, #4ade80 0%, #22c55e 14%, #1d9d52 48%, #137a3e 100%);
  border-color: rgba(220, 252, 231, 0.18);
  color: #f9fafb;
}

.btn-secondary {
  background:
    linear-gradient(180deg, rgba(44, 56, 50, 0.96) 0%, rgba(22, 30, 27, 0.98) 100%);
  border-color: rgba(250, 204, 21, 0.14);
  color: #f3f4f6;
}

.btn[disabled] {
  opacity: 0.42;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04),
    inset 0 -6rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* ========== 下注选择器 ========== */

.bet-bar {
  width: 100%;
  text-align: center;
}

.status-text {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  width: 100%;
}

.bet-picker {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.bet-label {
  font-size: 24rpx;
  color: #fde68a;
  letter-spacing: 2rpx;
}

.bet-options {
  display: flex;
  gap: 20rpx;
}

.bet-chip {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 50% 38%, rgba(250, 204, 21, 0.28), rgba(234, 179, 8, 0.08) 72%),
    linear-gradient(180deg, #3a3520 0%, #2a2515 100%);
  border: 3rpx solid rgba(250, 204, 21, 0.6);
  color: #fde68a;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12),
    0 8rpx 20rpx rgba(0, 0, 0, 0.4);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.4);
}

.bet-chip:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.3);
}

@keyframes cardReveal {
  0% {
    opacity: 0;
    transform: translateY(14rpx) scale(0.92);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes cardReveal {
  0% {
    opacity: 0;
    transform: translateY(14rpx) scale(0.92);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
