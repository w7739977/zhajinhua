.room-page {
  min-height: 100vh;
  background: #121212;
  color: #fff;
  padding: 24rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
  position: relative;
}

.room-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.room-id {
  font-size: 30rpx;
}

.invite-btn {
  padding: 0 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  background: #1e88e5;
  color: #fff;
  border-radius: 999rpx;
  border: none;
}

.other-players {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.other-player-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.other-player-item .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #333;
  margin-bottom: 6rpx;
}

.other-player-item .nickname {
  font-size: 22rpx;
  color: #999;
}

.center-card {
  text-align: center;
  margin-bottom: 48rpx;
  min-height: 48rpx;
}

.center-card-label {
  color: #999;
  font-size: 28rpx;
}

/* 通用扑克牌样式，较小尺寸 */
.poker-card {
  width: 70rpx;
  height: 100rpx;
  border-radius: 10rpx;
  border: 2rpx solid #e0e0e0;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.35);
}

.poker-card-large {
  width: 80rpx;
  height: 110rpx;
  display: inline-flex;
  margin-left: 8rpx;
}

.poker-card-text {
  font-size: 24rpx;
  color: #222;
}

.self-block {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.self-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #333;
  border: 4rpx solid #ffd54f;
  margin-bottom: 12rpx;
}

.self-nickname {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.self-card-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.self-hand-label {
  font-size: 26rpx;
  color: #ccc;
}

.self-hand-card {
  font-size: 32rpx;
  color: #ffd54f;
}

.self-hand-card.placeholder {
  color: #666;
  font-size: 26rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-evenly;
  padding: 0 32rpx;
}

.btn {
  width: 42%;
}

/* 底部按钮现代化样式 */
.btn {
  width: 42%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 28rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #ffb74d, #ff7043);
  color: #121212;
}

.btn-secondary {
  background: #2d2d2d;
  color: #ffffff;
}

.btn[disabled] {
  opacity: 0.4;
}
