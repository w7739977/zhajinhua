<view class="container">
  <view class="title">诈金花</view>

  <view class="action-panel" wx:if="{{!showAuthModal}}">
    <view class="action-row btn-primary" bindtap="onCreateRoom">创建房间</view>
    <view class="action-row btn-secondary" bindtap="onJoinRoom">加入房间</view>
    <block wx:if="{{showJoinInput}}">
      <view class="action-row input-row">
        <input
          class="action-input"
          placeholder="请输入房间号"
          maxlength="10"
          bindinput="onRoomIdInput"
          value="{{joinRoomId}}"
        />
      </view>
      <view class="action-row btn-primary" bindtap="onConfirmJoin">确认加入</view>
    </block>
  </view>

  <view class="auth-mask" wx:if="{{showAuthModal}}">
    <view class="auth-modal">
      <view class="auth-header">
        <text class="auth-title">进入前请先确认昵称头像</text>
        <text class="auth-desc">先授权微信头像昵称，再选择直接使用或输入自定义昵称，确认后才能进入大厅。</text>
      </view>

      <view class="profile-preview" wx:if="{{authorizedUserInfo}}">
        <image class="profile-avatar" src="{{authorizedUserInfo.avatarUrl}}" mode="aspectFill" />
        <text class="profile-name">{{authorizedUserInfo.nickName || '微信用户'}}</text>
      </view>

      <view class="auth-action-group">
        <view class="action-row btn-primary" bindtap="getUserProfile">授权头像及昵称</view>
        <view class="action-row input-row">
          <input
            class="action-input"
            placeholder="可输入你想展示的昵称"
            maxlength="12"
            bindinput="onNicknameInput"
            value="{{customNickName}}"
          />
        </view>
        <view class="action-row btn-secondary" bindtap="onConfirmProfile">确认并进入大厅</view>
      </view>
    </view>
  </view>
</view>

