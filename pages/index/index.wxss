.container {
  min-height: 100vh;
  padding: 64rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 48rpx;
  background: #121212;
}

.title {
  font-size: 60rpx;
  font-weight: 700;
  color: #f9fafb;
  letter-spacing: 1rpx;
  text-align: center;
  align-self: center;
}


.subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #9ca3af;
  line-height: 1.6;
}

.join-wrap {
  width: 100%;
  margin-top: 8rpx;
}

.room-input {
  width: 100%;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  background: #18181b;
  border: 1rpx solid #3f3f46;
  font-size: 28rpx;
  color: #f9fafb;
  box-shadow: 0 10rpx 25rpx rgba(0, 0, 0, 0.65);
}

.room-input::placeholder {
  color: #6b7280;
}

.btn {
  width: 100%;
  margin-bottom: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.7);
}

.btn-primary {
  background: #2563eb;
  color: #f9fafb;
}

.btn-primary:active {
  background: #1d4ed8;
}

.btn-secondary {
  background: #27272a;
  color: #e5e7eb;
}

.btn-ghost {
  background: transparent;
  color: #9ca3af;
  border: 1rpx solid #3f3f46;
  box-shadow: none;
}

.btn[disabled] {
  opacity: 0.35;
  box-shadow: none;
}

.user-btn {
  margin-top: 40rpx;
}
