.container {
  min-height: 100vh;
  padding: 64rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 48rpx;
  background:
    radial-gradient(circle at 50% 18%, rgba(110, 231, 183, 0.08), transparent 22%),
    radial-gradient(circle at 15% 82%, rgba(16, 185, 129, 0.06), transparent 24%),
    radial-gradient(circle at 82% 78%, rgba(5, 46, 22, 0.32), transparent 28%),
    linear-gradient(180deg, #14382a 0%, #0d281e 54%, #081510 100%);
}

.title {
  font-size: 60rpx;
  font-weight: 700;
  color: #f9fafb;
  letter-spacing: 1rpx;
  text-align: center;
  align-self: center;
}

.action-panel {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* --- 统一行：按钮与输入框共用 --- */
.action-row {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.42);
}

.action-row.btn-primary {
  background: #2563eb;
  color: #f9fafb;
}

.action-row.btn-primary:active {
  background: #1d4ed8;
}

.action-row.btn-secondary {
  background: rgba(11, 31, 24, 0.72);
  color: #e5e7eb;
  border: 1rpx solid rgba(134, 239, 172, 0.08);
}

.action-row.input-row {
  background: rgba(7, 24, 18, 0.76);
  border: 1rpx solid rgba(110, 231, 183, 0.12);
  overflow: hidden;
  line-height: normal;
}

.action-row.input-row .action-input {
  width: 100%;
  height: 100%;
  padding: 0 28rpx;
  margin: 0;
  border: none;
  background: transparent;
  box-shadow: none;
  font-size: 30rpx;
  color: #f9fafb;
  line-height: 88rpx;
  box-sizing: border-box;
}

.action-row.input-row .action-input::placeholder {
  color: #6b7280;
}

/* --- 授权弹框 --- */
.auth-mask {
  position: fixed;
  inset: 0;
  background: rgba(1, 10, 7, 0.68);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.auth-modal {
  width: 100%;
  max-width: 620rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(110, 231, 183, 0.06), transparent 34%),
    linear-gradient(180deg, rgba(19, 52, 39, 0.94) 0%, rgba(10, 27, 20, 0.96) 100%);
  border: 1rpx solid rgba(110, 231, 183, 0.14);
  border-radius: 28rpx;
  padding: 48rpx 36rpx 40rpx;
  box-sizing: border-box;
  box-shadow: 0 30rpx 70rpx rgba(0, 0, 0, 0.4);
}

.auth-header {
  margin-bottom: 32rpx;
}

.auth-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #f9fafb;
  text-align: center;
  line-height: 1.35;
}

.auth-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: #9ca3af;
  text-align: center;
  padding: 0 8rpx;
}

.profile-preview {
  margin: 0 0 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 22rpx 0 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 999rpx;
  border: 3rpx solid rgba(37, 99, 235, 0.8);
  background: #27272a;
}

.profile-name {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e7eb;
  line-height: 1.4;
}

.auth-action-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
