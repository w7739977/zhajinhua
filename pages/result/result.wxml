<view class="result-page">
  <view class="header">
    <text>房间号：{{roomId}}</text>
  </view>

  <view class="public-card" wx:if="{{publicCard}}">
    <text class="public-label">公牌：</text>
    <view class="poker-card poker-card-large">
      <text class="poker-card-text">{{publicCard.text || publicCard}}</text>
    </view>
  </view>

  <view class="players-list">
    <block wx:for="{{players}}" wx:key="openId">
      <view class="player-row">
        <image class="avatar" src="{{item.avatarUrl || defaultAvatar}}" mode="aspectFill" />
        <view class="info">
          <text class="name">{{item.nickName || '玩家'}}</text>
          <view class="card" wx:if="{{item.card}}">
            <text class="card-label">手牌：</text>
            <view class="poker-card">
              <text class="poker-card-text">{{item.card.text || item.card}}</text>
            </view>
          </view>
          <text class="card placeholder" wx:else>手牌：未发牌</text>
        </view>
      </view>
    </block>
  </view>

  <button class="back-btn" bindtap="onBack">
    返回游戏
  </button>
</view>

