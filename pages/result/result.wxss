.result-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 50% 18%, rgba(110, 231, 183, 0.1), transparent 20%),
    radial-gradient(circle at 18% 82%, rgba(16, 185, 129, 0.08), transparent 26%),
    radial-gradient(circle at 82% 18%, rgba(16, 185, 129, 0.08), transparent 24%),
    linear-gradient(180deg, #163e2f 0%, #0d291f 50%, #081510 100%);
  padding: 32rpx 32rpx 160rpx;
  box-sizing: border-box;
  box-shadow:
    inset 0 0 140rpx rgba(0, 0, 0, 0.22),
    inset 0 0 26rpx rgba(255, 255, 255, 0.02);
}

.header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.header text {
  font-size: 28rpx;
  color: #e5e7eb;
}

.mode-badge {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(250, 204, 21, 0.16);
  color: #fde68a !important;
  font-size: 22rpx !important;
  border: 1rpx solid rgba(250, 204, 21, 0.3);
}

.pass-dealer-tip {
  text-align: center;
  margin-bottom: 20rpx;
  padding: 14rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(250, 204, 21, 0.1);
  border: 1rpx solid rgba(250, 204, 21, 0.25);
}

.pass-dealer-tip text {
  font-size: 24rpx;
  color: #fde68a;
}

.dealer-loss-tip {
  text-align: center;
  margin-bottom: 20rpx;
  padding: 14rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(239, 68, 68, 0.1);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.dealer-loss-tip text {
  font-size: 24rpx;
  color: #fca5a5;
}

.dealer-section-loss {
  border-color: rgba(239, 68, 68, 0.35) !important;
  background:
    radial-gradient(circle at 50% 38%, rgba(239, 68, 68, 0.08), transparent 50%),
    rgba(8, 27, 20, 0.62) !important;
}

.dealer-loss-badge {
  margin-left: auto;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(239, 68, 68, 0.18);
  color: #fca5a5;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid rgba(239, 68, 68, 0.35);
}

/* ========== 区块标题 ========== */

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: rgba(220, 252, 231, 0.8);
  letter-spacing: 2rpx;
}

.section-title-icon {
  font-size: 28rpx;
}

/* ========== 庄家区域 ========== */

.dealer-section {
  margin-bottom: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 50% 38%, rgba(250, 204, 21, 0.08), transparent 50%),
    rgba(8, 27, 20, 0.62);
  border: 1rpx solid rgba(250, 204, 21, 0.2);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(6rpx);
}

.dealer-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.player-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar-wrap-result {
  position: relative;
  display: inline-block;
  flex-shrink: 0;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #27272a;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
}

.avatar-dealer-result {
  border: 4rpx solid rgba(250, 204, 21, 0.9) !important;
  box-shadow: 0 0 0 4rpx rgba(250, 204, 21, 0.15);
}

.crown-result {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  font-size: 26rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.5));
}

.player-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.player-name {
  font-size: 28rpx;
  color: #f9fafb;
  font-weight: 600;
}

.hand-type-tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(110, 231, 183, 0.14);
  color: #86efac;
  font-size: 20rpx;
  align-self: flex-start;
}

/* ========== 牌展示 ========== */

.cards-row {
  display: flex;
  gap: 14rpx;
  align-items: flex-end;
}

.card-with-label {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.card-label-mini {
  font-size: 18rpx;
  color: rgba(220, 252, 231, 0.5);
}

.poker-card {
  width: 70rpx;
  height: 100rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(243, 244, 246, 0.24);
  background: #f9fafb;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.65);
  animation: cardReveal 360ms ease-out;
}

.poker-card-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.poker-card-text-red {
  color: #dc2626;
}

/* ========== 喝酒 & 累计 ========== */

.score-change-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.drinks-tag {
  font-size: 28rpx;
  font-weight: 700;
  color: #fbbf24;
}

.drinks-zero {
  font-size: 24rpx;
  font-weight: 400;
  color: #6b7280;
}

.score-total {
  font-size: 22rpx;
  color: #9ca3af;
}

.settle-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bet-info {
  font-size: 22rpx;
  color: #fde68a;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(250, 204, 21, 0.12);
}

/* ========== 玩家对比列表 ========== */

.players-section {
  margin-bottom: 40rpx;
}

.player-result-card {
  position: relative;
  margin-bottom: 18rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(8, 27, 20, 0.62);
  border: 1rpx solid rgba(110, 231, 183, 0.1);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.25);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.result-badge {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.result-win {
  background: rgba(34, 197, 94, 0.18);
  color: #86efac;
  border: 1rpx solid rgba(34, 197, 94, 0.3);
}

.result-lose {
  background: rgba(239, 68, 68, 0.16);
  color: #fca5a5;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.result-tie {
  background: rgba(107, 114, 128, 0.16);
  color: #d1d5db;
  border: 1rpx solid rgba(107, 114, 128, 0.3);
}

.result-neutral {
  background: rgba(107, 114, 128, 0.12);
  color: #9ca3af;
  border: 1rpx solid rgba(107, 114, 128, 0.2);
}

/* ========== 底部按钮 ========== */

.back-btn {
  position: fixed;
  left: 10%;
  right: 10%;
  bottom: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(250, 204, 21, 0.16);
  background:
    linear-gradient(180deg, #4ade80 0%, #22c55e 16%, #1c9a50 52%, #137a3e 100%);
  color: #f9fafb;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.28);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08),
    inset 0 -10rpx 16rpx rgba(0, 0, 0, 0.12),
    0 18rpx 45rpx rgba(0, 0, 0, 0.26);
}

@keyframes cardReveal {
  0% {
    opacity: 0;
    transform: translateY(14rpx) scale(0.92);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
