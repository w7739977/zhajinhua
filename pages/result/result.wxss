.result-page {
  min-height: 100vh;
  background: #121212;
  padding: 32rpx 32rpx 140rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.header text {
  font-size: 28rpx;
  color: #e5e7eb;
}

.public-card {
  text-align: center;
  margin-bottom: 32rpx;
}

.public-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-right: 10rpx;
}

/* 扑克牌：与房间页统一 */
.poker-card {
  width: 70rpx;
  height: 100rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(243, 244, 246, 0.24);
  background: #f9fafb;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 35rpx rgba(0, 0, 0, 0.75);
}

.poker-card-large {
  width: 80rpx;
  height: 110rpx;
}

.poker-card-text {
  font-size: 24rpx;
  color: #111827;
}

.players-list {
  background: #18181b;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 18rpx 45rpx rgba(0, 0, 0, 0.85);
  margin-bottom: 80rpx;
}

.player-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #27272a;
}

.player-row:last-child {
  border-bottom: none;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #27272a;
  margin-right: 16rpx;
}

.info {
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 26rpx;
  color: #f9fafb;
  margin-bottom: 6rpx;
}

.card {
  font-size: 24rpx;
  color: #d1d5db;
}

.card-label {
  margin-right: 8rpx;
}

.card.placeholder {
  color: #6b7280;
}

.back-btn {
  position: fixed;
  left: 10%;
  right: 10%;
  bottom: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
  background: #2563eb;
  color: #f9fafb;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 18rpx 45rpx rgba(37, 99, 235, 0.8);
}
